# Registry Configuration
USE_LOCAL_REGISTRY=true
REGISTRY_URL=localhost:5000

# Runner Configuration
# Comma-separated list of Dockerfile names (without "Dockerfile." prefix)
# Example: RUNNERS=yocto-runner-ubuntu-22.04,yocto-runner-debian-12,yocto-runner-fedora-42
# Use yocto-runner-crops for automatic UID/GID mapping (recommended)
RUNNERS=yocto-runner-ubuntu-22.04,yocto-runner-ubuntu-24.04

# Number of runner instances to start (for parallel builds)
RUNNER_REPLICAS=1

# Forgejo Admin Credentials (for auto-registration)
FORGEJO_ADMIN_USER=forgejo

# Optional: Manual Runner Token (if auto-registration fails)
FORGEJO_RUNNER_TOKEN=

# Forgejo Configuration
FORGEJO_VERSION=14.0.1
FORGEJO_DOMAIN=localhost
FORGEJO_ROOT_URL=http://localhost:3000/
